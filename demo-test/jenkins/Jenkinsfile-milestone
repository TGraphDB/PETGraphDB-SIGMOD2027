#!/usr/bin/env groovy
@Library('tgraph-demo-test') import main.groovy.JenkinsTGraphTest as JTT


pipeline {
    parameters {
        string(name:'dataset', defaultValue: "energy", description: 'Datasets')
        string(name:'data_size', defaultValue: "T_01", description: 'Temporal Property Data Size')
        string(name:'db_name', defaultValue: 'TGS', description: 'DB Name')
        string(name:'device', defaultValue: 'server', description: 'Device')
        string(name:'compile', defaultValue: 'test', description: 'Module to Compile')
        string(name:'debug', defaultValue: 'false')
        string(name:'cleanup', defaultValue: 'yes')
    }
    agent {
        label params.device
    }
    environment {
        MILESTONE_NAME = JTT.milestoneName(params.dataset, params.data_size, params.db_name)

        CONFIG_NEO4J_NO_LOG = 'nolog'
        CONFIG_MEMTABLE_SIZE = '64'
        CONFIG_FBUFFER_SIZE = '32'


        DIR_BUILD = JTT.dir('DIR_BUILD', env.NODE_NAME)
        DIR_ARTIFACT = JTT.dir('DIR_ARTIFACT', env.NODE_NAME)
//        DIR_MARIADB_DATA = JTT.dir('DIR_MARIADB_DATA', env.NODE_NAME)
//        MAVEN_OPTS='-Xmx4g -Xms1g'
        JENKINS_ID = "${BUILD_NUMBER}"
        MARK_TIME = JTT.timeNow()
//        DEVICE="${params.device}"
    }
    stages {
        stage('Clean up'){
            steps {
                echo "Build on ${env.NODE_NAME}"
                script{
                    currentBuild.description = "${currentBuild.description==null?'':currentBuild.description} ${params.dataset}(${params.data_size})@${params.db_name} on ${env.NODE_NAME}"
                    JTT.webhook(this, "build", env.BUILD_NUMBER, 'STARTED', currentBuild.result, params)
                    def conf = readYaml(file:'tests.yml')
                    echo "${conf.dbinfo}"
                    withEnv(JTT.extendEnvList(conf.dbinfo, params.db_name)){
                        echo "drop db ${MILESTONE_NAME}"
                        JTT.dropDB(this, env.MILESTONE_NAME, env)
                    }
                }
            }
        }
        stage('Building') {
            environment {
                MARK_TIME = JTT.timeNow()
                MAVEN_OPTS = "${JTT.opt('MAVEN_BUILD_OPTS', env.NODE_NAME)} -XX:CICompilerCount=3 -XX:ParallelGCThreads=6" // -XX:+UseG1GC -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=5005'
                DEVICE =   "${env.NODE_NAME}"
                DB_HOST =  "${params.device}"
                DB_PATH =   JTT.dir('DIR_BUILD', env.NODE_NAME, env.MILESTONE_NAME) //for neo4j/tgraph
                DB_NAME =   "${params.db_name}"
                DATASET =   "${params.dataset}"
                DATA_SIZE = "${params.data_size}"
                DATA_PATH = JTT.dir('DIR_DATA', env.NODE_NAME)
            }
            steps {
                echo "Milestone ${env.MILESTONE_NAME}@${env.DB_HOST}"
                script {
                    def serverParamStr = "--name b.s.${env.BUILD_NUMBER}-${env.MILESTONE_NAME} " // --rm
                    def clientParamStr = "--network=host --name b.c.${env.BUILD_NUMBER}-${env.MILESTONE_NAME} "
                    def conf = readYaml(file: 'tests.yml')
                    echo "${conf.dbinfo}"
                    echo "${conf.datainfo}"
                    def portCfg = JTT.extractConf(conf.dbinfo, "${params.db_name}", 'server_port')
                    serverParamStr = JTT.dockerPortStr(portCfg) + serverParamStr
                    def envMap = [
                            'DB_PORT':           JTT.serverPortForClient(portCfg),
                            'CLASS_DATA_IMPORT': JTT.extractConf(conf.dbinfo,   "${params.db_name}", 'class_data_import'),
                            'CLASS_DATA_GEN':    JTT.extractConf(conf.datainfo, "${params.dataset}", 'class_data_gen'),
                            "${params.data_size}":JTT.extractConf(conf.datainfo, "${params.dataset}", "${params.data_size}"),
                            'DB_NAME':   env.MILESTONE_NAME
                    ]
                    def dbPath = JTT.extractConf(conf.dbinfo, "${params.db_name}", 'server_data_path')

                    if(params.debug=='true') {
                        envMap["MAVEN_OPTS"] = "${MAVEN_OPTS} -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=5005"
                    }

                    def serverImage = JTT.extractConf(conf.dbinfo, "${params.db_name}", 'server_image')
                    if(serverImage.startsWith('songjinghe/tgraph-demo-test')){ // no need client, just start server.
                        def envMapArr = JTT.map2EnvList(envMap)
                        echo "envMapArr: ${envMapArr}"
                        serverParamStr += JTT.dockerVolumeStr([:], [env.DATA_PATH, env.DB_PATH])
                        echo "docker run params: ${serverParamStr}"
                        withEnv(envMapArr){
                            docker.image(serverImage).inside(serverParamStr) {
                                JTT.printJavaMavenVersion(this)
                                JTT.codeSyncAndCompile(this, "${params.compile}", false)
                                JTT.buildMilestone(this, currentBuild)
                            }
                        }
                    }else{ //  other databases.
                        envMap['MARIADB_ROOT_PASSWORD'] = "langduhua"
                        envMap['POSTGRES_PASSWORD'] = "langduhua"
                        // 用于添加与特定数据库相关的、可能与其他数据库冲突的环境变量；
                        JTT.addDbSpecifiedEnv(envMap, env.MILESTONE_NAME)
                        def envMapArr = JTT.map2EnvList(envMap)
                        echo "envMapArr: ${envMapArr}"
                        def volumeMap = [:]
                        volumeMap.put(env.DB_PATH, dbPath)
                        serverParamStr += JTT.dockerVolumeStr(volumeMap, [env.DATA_PATH])
                        clientParamStr += JTT.dockerVolumeStr(volumeMap, [env.DATA_PATH])
                        if(params.debug=='true') { // run client only, need manually start server.
                            def clientImage = JTT.extractConf(conf.dbinfo, "${params.db_name}", 'client_image')
                            withEnv(envMapArr) {
                                docker.image(clientImage).inside(clientParamStr) {
                                    JTT.printJavaMavenVersion(this)
                                    JTT.codeSyncAndCompile(this, "${params.compile}", false)
                                    JTT.buildMilestone(this, currentBuild)
                                }
                            }
                        }else{ // start server docker then start client docker image.
                            docker.image(serverImage).withRun(serverParamStr + ' ' + JTT.dockerEnvStr(envMap)) { c ->
                                echo 'server container started: ' + serverImage
                                def clientImage = JTT.extractConf(conf.dbinfo, "${params.db_name}", 'client_image')
                                withEnv(envMapArr) {
                                    docker.image(clientImage).inside(clientParamStr) {
                                        JTT.printJavaMavenVersion(this)
                                        JTT.codeSyncAndCompile(this, "${params.compile}", false)
                                        JTT.buildMilestone(this, currentBuild)
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        stage('Package Artifact') {
            steps {
                script {
                    // JTT.webhook(this, "build", env.BUILD_NUMBER, 'COMPLETED', currentBuild.result, params)
                    def conf = readYaml(file:'tests.yml')
                    echo "${conf.dbinfo}"
                    withEnv(JTT.extendEnvList(conf.dbinfo, params.db_name)){
                        JTT.archiveMilestone(this, env.DB_TYPE, env.MILESTONE_NAME, env)
                    }
                }
            }
        }
    }
    post{
        always {
            script {
                echo "stoping ${params.db_name}..."
                JTT.webhook(this, "build", env.BUILD_NUMBER, 'FINALIZED', currentBuild.result, params)
            }
        }
    }
}