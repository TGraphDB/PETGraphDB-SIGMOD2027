#!/usr/bin/env groovy
@Library('tgraph-demo-test') import main.groovy.JenkinsTGraphTest as JTT

//测试
pipeline {
    agent none
    parameters {
        string(name:'db_host', defaultValue: 'server')
        string(name:'milestone', defaultValue: 'm_energy_pg_01')
        string(name:'benchmark_name', defaultValue: 'b_energy_T.01_ehistory_100')
        choice(name:'max_connection', choices:['1', '2', '4', '8', '12', '16'])
        string(name:'need_result', defaultValue: 'true')
        string(name:'debug', defaultValue: 'false')
        string(name:'timeout_p', defaultValue: '360', description: 'failed if no more output within XXX seconds')
        string(name:'timeout', defaultValue: '7200', description: 'failed if not complete within XXX seconds')
    }
    environment {
        DB_NAME = "${params.milestone}"
        MAX_CONNECTION_CNT = "${params.max_connection}"
        DEVICE="${params.db_host}"
        NEED_RESULT = "${params.need_result}"
        MARK_TIME = JTT.timeNow()
        JENKINS_ID = "${BUILD_NUMBER}"
        BENCHMARK_NAME = "${params.benchmark_name}"
    }
    stages {
        stage('Prepare') {
            failFast true
            parallel {
                stage('Client'){
                    agent {
                        label 'client'
                    }
                    steps {
                        timestamps {
                            echo "At least one client ready: ${env.NODE_NAME}"
                        }
                    }
                }
                stage('Server'){
                    agent {
                        label params.db_host
                    }
                    steps {
                        timestamps {
                            echo "${env.NODE_NAME}: server starting..."
                            script{
                                currentBuild.description = "${params.benchmark_name} on ${params.milestone}@${DB_HOST}(${params.max_connection})"
                                def (DATASET, DB) = JTT.extract(params.milestone)
                                def retcode = JTT.ctrlDB(this, 'start', DB)
                                if(retcode==0 || retcode==2){
                                    echo "${env.NODE_NAME}: server ready."
                                }else{
                                    error "Unable to start ${DB} on ${env.NODE_NAME}"
                                }
                            }
                        }
                    }
                }
            }
        }
        stage('Benchmarking') {
            failFast true
            parallel {
                stage('Client'){
                    agent {
                        label 'client'
                    }
                    environment {
                        DIR_BENCHMARK = JTT.dir('DIR_BENCHMARK', env.NODE_NAME, params.benchmark_name)
                        MAVEN_OPTS= JTT.opt('MAVEN_OPTS', env.NODE_NAME)
                    }
                    steps {
                        script {
                            sleep 12
                            dir(JTT.dir('DIR_CODE', env.NODE_NAME, 'demo-test')){
                                def conf = readYaml(file:'tests.yml')
                                def (DATASET, DB) = JTT.extract(params.milestone)
                                echo "${params.benchmark_name} on ${params.milestone}@${env.NODE_NAME}->${DB_HOST}(${params.max_connection})"
                                def env1 = JTT.extendEnvList(conf.dbinfo, DB)
                                def env2 = JTT.map2EnvList(['dataset': DATASET, 'db': DB])
                                echo env1.toString()
                                echo env2.toString()
                                withEnv(env1+env2){
                                    withEnv([
                                        "BENCHMARK_FULL_PATH=${DIR_BENCHMARK}\\benchmark.json",
                                        "BENCHMARK_RESULT_PATH=${DIR_BENCHMARK}\\${DB}.result.json",
                                        "DB_HOST=${params.db_host}",
                                        "DB_NAME=${params.milestone}",
                                        "DEVICE=${params.db_host}"
                                    ]){
                                        echo "Benchmarking ${params.milestone}@${env.DB_HOST} with file ${env.BENCHMARK_FULL_PATH} NEED_RESULT: ${env.NEED_RESULT}"
                                        bat "mvn -B exec:java -Dexec.mainClass=edu.buaa.common.benchmark.BenchmarkRunner -Dexec.cleanupDaemonThreads=false"
                                    }
                                }
                            }
                        }
                        echo "Client_Finish_Amitabha"
                    }
                }
                stage('Watchdog'){
                    agent {
                        label 'master'
                    }
                    environment {
                        TIMEOUT = "${params.timeout}"
                        TIMEOUT_PROGRESS = "${params.timeout_p}"
                        LOG_PIPE = "${currentBuild.rawBuild.getLogFile().getAbsolutePath()}"
                        MARKERS = 'Client_Finish_Amitabha,Server_Finish_Amitabha'
                    }
                    steps {
                        echo "Watch dog start on: ${env.LOG_PIPE}"
                        sleep 20
                        echo "timeout: ${env.TIMEOUT}s timeout_p: ${TIMEOUT_PROGRESS}s"
                        dir(JTT.dir('DIR_CODE', env.NODE_NAME, 'demo-test')) {
                            bat "mvn -q exec:java -Dexec.mainClass=edu.buaa.utils.TimeoutWatchDog -Dexec.cleanupDaemonThreads=false 2>&1" // | tee -a watchdog-${params.class_client}.log
                        }
                    }
                }
                stage('Server'){
                    agent {
                        label params.db_host
                    }
                    environment {
                        DB_PATH = JTT.dir('DIR_WORKSPACE', env.NODE_NAME, params.milestone)
                        MAVEN_OPTS= JTT.opt('MAVEN_OPTS', env.NODE_NAME)
                    }
                    steps {
                        timestamps {
                            echo "${env.DB_PATH}@${env.NODE_NAME}"
                        }
                        dir(JTT.dir('DIR_CODE', env.NODE_NAME, 'demo-test')) {
                            script{
                                def (DATASET, DB) = JTT.extract(params.milestone)
                                def conf = readYaml(file:'tests.yml')
                                def server = JTT.getCor('class_server', conf.dbinfo.key, conf.dbinfo[DB] )
                                def port = JTT.getCor('db_port', conf.dbinfo.key, conf.dbinfo[DB] )
                                if(params.debug=='true') {
                                    withEnv(["DATASET=${DATASET}","DB_PORT=${port}", "MAVEN_OPTS=${MAVEN_OPTS} -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=5005"]){
                                        bat "mvn -B exec:java -Dexec.mainClass=${server} -Dexec.cleanupDaemonThreads=false"
                                        echo "Server_Finish_Amitabha"
                                    }
                                }else{
                                    withEnv(["DATASET=${DATASET}","DB_PORT=${port}"]){
                                        bat "mvn -B exec:java -Dexec.mainClass=${server} -Dexec.cleanupDaemonThreads=false"
                                        echo "Server_Finish_Amitabha"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    post{
        always {
            node(params.db_host) {
                script {
                    def (DATASET, DB) = JTT.extract(params.milestone)
                    echo "stoping ${DB}..."
                    def retCode = JTT.ctrlDB(this, 'stop', DB)
                    if(retCode!=0) echo "net stop return ${retCode}"
                }
            }
        }
    }
}