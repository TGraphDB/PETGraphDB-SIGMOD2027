pipeline {
    //在每个stage中指定使用节点
    agent none
    tools {
        maven 'maven'
        jdk   'jdk8'
    }
    parameters {
        string(name:'dataset', defaultValue: "syn", description: 'Datasets')
        string(name:'data_size', defaultValue: "T.01", description: 'Temporal Property Data Size')
        string(name:'db_name', defaultValue: 'TGK', description: 'DB Name')
        string(name: 'query_dist', defaultValue: 'w5r5', description: 'append, update, entity_history, snapshot, aggr_max, aggr_dur, entity_temporal_condition, reachable_area')
        string(name: 'query_size', defaultValue: '1000', description: 'Number of queries in benchmark')
        choice(name: 'max_connection_count', defaultValue: '16', description: 'Number of max connection to db server')
        booleanParam(name: 'need_result', defaultValue: "false", description: 'will use max_connection_count=1')
    }
    environment {
        NEED_RESULT = "${params.need_result}"
        MAX_CONNECTION_CNT = "${params.max_connection_count}"
        SSD_WORKSPACE = "G:\\jenkins-workspace"
        ARTIFACT_DIR = "D:\\tgraph\\jenkins"
        BENCHMARK_FILE = "benchmark.${params.tp_size}.${params.size}#${params.max_connection_count}"
        BENCHMARK_FULL_PATH = "${ARTIFACT_DIR}\\${env.BENCHMARK_FILE}"
        DATA_FULL_PATH = "D:\\tgraph\\data\\${params.dataset}"
    }
    stages {
        stage('Compile') {
            parallel {
                stage('Client') {
                    agent { label 'master' }
                    steps {
                        ws(env.SSD_WORKSPACE){
                            gitPullMvnBuild()
                        }
                    }
                }
                stage('Server') {
                    agent { label 'ssworkstation' }
                    steps {
                        ws('E:\\tgraph\\jenkins-workspace') {
                            gitPullMvnBuild()
                        }
                    }
                }
            }
        }
        stage('Generate Benchmark') {
            agent { label 'master' }
            when {
                beforeAgent true
                anyOf {
                    expression { params.rebuild_benchmark }
                    expression {
                        fExist(env.ARTIFACT_DIR, env.BENCHMARK_FILE) != 'exist'
                    }
                }
            }
            environment {
                BENCHMARK_SIZE = "${params.size}"
                BENCHMARK_DIST = "${params.query_distribution}"
                TP_RANGE = "${params.tp_size}"
            }
            steps{
                echo "Generating benchmark......"
                dir(env.SSD_WORKSPACE) {
                    dir('demo-test') {
                        bat "mvn -B exec:java -Dexec.mainClass=edu.buaa.${params.dataset}.BenchmarkBuilder -Dexec.cleanupDaemonThreads=false"
                    }
                }
                ws(env.ARTIFACT_DIR) {
                    archiveArtifacts artifacts: "${env.BENCHMARK_FILE}", fingerprint: true, followSymlinks: false, onlyIfSuccessful: true
                }
            }
        }
        stage('Run Test') {
            environment {
                DATASET = "${params.dataset}"
                TP_SIZE = "${params.tp_size}"
                ALLOW_TX_FAILURE = 'true'
            }
            matrix {
                axes {
                    axis {
                        name 'DB'
                        values 'neo4j2'//'tgraph_kernel_E'//, 'postgresql'//, , 'neo4j1', 'mariadb' //, 'tgraph_kernel', 
                    }
                    axis {
                        name 'DATASET'
                        values 'traffic', 'energy', 'syn'
                    }
                }
                stages {
                    stage('Prepare Milestone') {
                        steps {
                            lock(label:'test', quantity:1, resource: null){
                                echo "Prepare Milestone: ${DATASET} on ${DB}"
                                build job: 'test', parameters: [
                                    string(name: 'db_host', value: "${DB}"), 
                                    string(name: 'class_client', value: "${DATASET}"), 
                                    string(name: 'class_server', value: "${TP_SIZE}"),
                                    string(name: 'benchmark_path', value: "${TP_SIZE}"),
                                    string(name: 'benchmark_result_path', value: ""),
                                    string(name: 'max_connection_count', value: "1"),
                                    string(name: 'timeout', value: "300")
                                ]
                            }
                            build job: 'milestone-deploy', parameters: [
                                string(name: 'target_host', value: "${DB}"), 
                                string(name: 'dbtype', value: "${DB}"), 
                                string(name: 'dbname', value: "${DATASET}"), 
                                string(name: 'milestone', value: "${TP_SIZE}"), 
                            ]
                        }
                    }
                    stage('Benchmarking') {
                        steps {
                            script {
                                def DB_HOST = (("${DB}"=='postgresql' || "${DB}"=='mariadb') ? 'zhworkstation' : 'ssworkstation')
                                withEnv(["DB_HOST=${DB_HOST}"]){
                                    lock("${DB_HOST}"){
                                        echo "Testing ${DATASET} on ${DB}(${params.max_connection_count})@${DB_HOST} with ${BENCHMARK_FULL_PATH}"
                                        timeout(60) { //minute time: activity: true, 
                                            build job: 'test', parameters: [
                                                string(name: 'db', value: "${DB}"), 
                                                string(name: 'dataset', value: "${DATASET}"),
                                                string(name: 'db_host', value: "${DB_HOST}"),
                                                string(name: 'benchmark_path', value: "${BENCHMARK_FULL_PATH}"),
                                                string(name: 'max_connection_count', value: "${params.max_connection_count}"),
                                                string(name: 'benchmark_result_path', value: '')
                                            ]
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}