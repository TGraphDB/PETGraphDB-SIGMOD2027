#!/usr/bin/env groovy
@Library('tgraph-demo-test') import main.groovy.JenkinsTGraphTest as JTT

//校验结果

pipeline {
    agent none
    parameters {
        string(name:'db_host', defaultValue: 'data')
        string(name:'db_list', defaultValue: 'pg,tgk', description: 'Test DBS (,ma,n1,n2)')
        string(name:'dataset', defaultValue: 'energy')
        string(name:'test', defaultValue: 'ehistory')
        string(name:'tp_range', defaultValue: 'T.01')
        string(name:'req_cnt', defaultValue: '10')
        string(name:'sample_mode', defaultValue: 'extend')
        string(name:'skip_sample', defaultValue: 'false')
        string(name:'skip_test', defaultValue: 'false')
        string(name:'skip_validate', defaultValue: 'false')
        choice(name:'max_connection', choices:['1', '2', '4', '8', '12', '16'], description: 'Max Connections to server')
        string(name:'timeout', defaultValue: '1800', description: 'failed if no more output within XXX seconds')
        string(name:'fail_fast', defaultValue: 'false')
    }
    environment {
        SAMPLE_MODE = "${params.sample_mode}"
        DATASET = "${params.dataset}"
        REQ_TYPE = "${params.test}"
        REQ_CNT = "${params.req_cnt}"
        DATA_SIZE = "${params.tp_range}"
        BENCHMARK_NAME = JTT.benchmarkName(params.dataset, params.tp_range, Integer.parseInt(params.req_cnt), params.test)
        JENKINS_ID = "${BUILD_NUMBER}"
    }
    stages {
        stage('Prepare') {
            agent {
                label 'master'
            }
            steps{
                script{
                    currentBuild.description = "${currentBuild.description==null?'':currentBuild.description} ${BENCHMARK_NAME}@${params.db_list}"
                }
            }
        }
        stage('Generate Benchmark') {
            when {
                beforeAgent true
                expression { params.skip_sample != 'true' }
            }
            agent {
                label 'client'
            }
            steps{
                script{
                    // dir(JTT.dir('DIR_CODE', env.NODE_NAME)){
                    //     if(currentBuild.getBuildCauses('hudson.model.Cause$UserIdCause').size() > 0){//triggered by user manually
                    //         JTT.codeSyncAndCompile(this, 'test') //'tcypher', 'neo4j', 'tp'
                    //     }
                    // }
                    echo "Benchmark sample at ${env.NODE_NAME}"
                    dir(JTT.dir('DIR_CODE', env.NODE_NAME, 'demo-test')) {
                        def conf = readYaml(file:'tests.yml')
                        echo "${conf.dbinfo}"
                        echo "${conf.datainfo}"
                        String DIR_BENCHMARK = JTT.dir('DIR_BENCHMARK', env.NODE_NAME)
                        withEnv(JTT.extendEnvList(conf.datainfo, params.dataset)){
                            withEnv(JTT.extendEnvList(conf.queryinfo, params.test)){
                                def bFolder = "${DIR_BENCHMARK}\\${BENCHMARK_NAME}"
                                if(params.skip_sample != 'true'){
                                    withEnv(["BENCHMARK_FULL_PATH=${bFolder}\\benchmark.json", "DIR_DATA=${JTT.dir('DIR_DATA', env.NODE_NAME)}"]){ //"DIR_BENCHMARK=${DIR_BENCHMARK}", 
                                        bat "mvn -B exec:java -Dexec.mainClass=edu.buaa.common.benchmark.BenchmarkSampler -Dexec.cleanupDaemonThreads=false"
                                    }
                                    bat "echo ${JENKINS_ID} > ${bFolder}\\JENKINS_ID"
                                }
                            }
                        }
                    }
                }
            }
        }
        stage('Test') {
            when {
                beforeAgent true
                expression { params.skip_test != 'true' }
            }
            steps{
                script{
                    def branches = [:]
                    int i=0
                    for (String dbname : params.db_list.split(',')) {
                        def DB = dbname
                        int waitT = i*12
                        i++
                        branches[DB] = {
                            sleep waitT
                            lock(label:'test', quantity: 1, resource: null){
                                String mName = JTT.milestoneName(DATASET, DATA_SIZE, DB)
                                echo "Testing ${BENCHMARK_NAME} on ${DATASET}(${DATA_SIZE})@${DB}"
                                build job: 'test', parameters: [
                                    string(name: 'db_host', value: params.db_host),
                                    string(name: 'benchmark_name', value: "${BENCHMARK_NAME}"),
                                    string(name: 'milestone', value: mName), //DATA_SIZE
                                    string(name: 'max_connection', value: params.max_connection),
                                    string(name: 'need_result', value: params.skip_validate=='true'?'false':'true'),
                                    string(name: 'timeout', value: params.timeout)
                                ]
                            }
                        }
                    }
                    if(params.fail_fast=='true') branches.failFast=true
                    parallel branches
                    echo 'all finish'
                }
            }
        }
        stage('Validate') {
            agent {
                label 'client'
            }
            when {
                beforeAgent true
                expression { params.skip_validate != 'true' }
            }
            environment {
                DIR_BENCHMARK = JTT.dir('DIR_BENCHMARK', env.NODE_NAME)
                BENCHMARK_DIR = "${DIR_ARTIFACT}\\${BENCHMARK_NAME}"
                DB_LIST = "${params.db_list}"
            }
            steps {
                echo "validate on ${env.NODE_NAME}"
                dir(JTT.dir('DIR_CODE', env.NODE_NAME, 'demo-test')) {
                    bat "mvn -B exec:java -Dexec.mainClass=edu.buaa.common.benchmark.BenchmarkValidator -Dexec.cleanupDaemonThreads=false"
                }
            }
        }
    }
}

