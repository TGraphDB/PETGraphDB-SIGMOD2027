#!/usr/bin/env groovy
@Library('tgraph-demo-test') import main.groovy.JenkinsTGraphTest as JTT

pipeline {
    agent none
    parameters {
        string(name: 'target_host', defaultValue: "data")
        string(name: 'dbtype', defaultValue: "neo4j")
        string(name: 'milestone', defaultValue: 'm_energy_tgs_all')
    }
    environment {
        PGPASSWORD = "langduhua"
        MARK_TIME = JTT.timeNow()
        DEVICE="${params.target_host}"
    }
    stages {
        stage('Deploy milestone') {
            agent {
                label params.target_host
            }
            environment {
                DIR_MARIADB_DATA = JTT.dir('DIR_MARIADB_DATA', env.NODE_NAME)
                DIR_BUILD = JTT.dir('DIR_BUILD', env.NODE_NAME)
                DIR_WORKSPACE = JTT.dir('DIR_WORKSPACE', env.NODE_NAME)
                DIR_ARTIFACT = JTT.dir('DIR_ARTIFACT', env.NODE_NAME)
            }
            steps {
                script {
                    def desp = "deploy ${params.milestone}@${params.target_host}(${params.dbtype})"
                    currentBuild.description = desp
                    echo desp
                    JTT.webhook(this, "deploy", env.BUILD_NUMBER, 'STARTED', currentBuild.result, params)
                    JTT.deploy2hdd(this, env, params.dbtype, params.milestone)
                }
            }
        }
    }
    post{
        always {
            script {
                JTT.webhook(this, "deploy", env.BUILD_NUMBER, 'COMPLETED', currentBuild.result, params)
            }
        }
    }
}
