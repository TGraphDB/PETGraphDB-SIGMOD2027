        stage('Compile') {
            parallel {
                stage('Master') {
                    agent { label 'master' }
                    steps {
                        dir(JTT.dir('DIR_CODE', env.NODE_NAME)){
                            script{
                                currentBuild.description = "recompile: ${params.code2compile}"
                                JTT.codeSyncAndCompile(this, params.code2compile) //'tcypher', 'neo4j', 'tp' 'test'
                            }
                        }
                    }
                }
                stage('SS') {
                    agent { label 'ssworkstation' }
                    steps {
                        script{
                            dir(JTT.dir('DIR_CODE', env.NODE_NAME)) {
