//测试
@Library('tgraph-demo-test') import main.groovy.JenkinsTGraphTest as JTT


pipeline {
    //在每个stage中指定使用节点
    agent none
    parameters {
        string(name:'code2compile', defaultValue: 'test', description: 'Available options: tcypher,neo4j,tp,test')  //
    }
